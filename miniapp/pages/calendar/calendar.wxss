/* 日历回顾页 */
.page-bg {
  min-height: 100vh;
  background: linear-gradient(180deg, #EDF2F4 0%, #F5F3EF 100%);
}

/* 月份导航 */
.month-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  margin-bottom: 24rpx;
}

.nav-arrow {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #4A90A4;
  background: rgba(255,255,255,0.7);
  border-radius: 50%;
}

.month-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #2C2C2C;
}

/* 周标题 */
.week-header {
  display: flex;
  margin-bottom: 16rpx;
}

.week-item {
  flex: 1;
  text-align: center;
  font-size: 24rpx;
  color: #aaa;
  padding: 12rpx 0;
}

/* 日期网格 */
.date-grid {
  display: flex;
  flex-wrap: wrap;
}

.date-cell {
  width: calc(100% / 7);
  aspect-ratio: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}

.date-cell.empty {
  visibility: hidden;
}

.cell-inner {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  transition: all 0.2s ease;
  position: relative;
}

.date-cell.today .cell-inner {
  background: rgba(74, 144, 164, 0.1);
  border: 2rpx solid rgba(74, 144, 164, 0.3);
}

.cell-day {
  font-size: 28rpx;
  color: #444;
  font-weight: 400;
}

.date-cell.today .cell-day {
  color: #4A90A4;
  font-weight: 600;
}

/* 完成度圆点 */
.cell-dots {
  display: flex;
  gap: 4rpx;
  margin-top: 4rpx;
}

.cell-dots .dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #A8C8D2;
}

.cell-empty-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #eee;
  margin-top: 4rpx;
}

/* 选中日期详情 */
.date-detail {
  margin-top: 40rpx;
  background: rgba(255,255,255,0.85);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.04);
}

.detail-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.detail-date {
  font-size: 30rpx;
  font-weight: 600;
  color: #2C2C2C;
}

.detail-rate {
  font-size: 24rpx;
  color: #4A90A4;
  background: rgba(74, 144, 164, 0.1);
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
}

/* 迷你目标 */
.mini-goal {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(0,0,0,0.04);
}

.mini-goal:last-child {
  border-bottom: none;
}

.mini-check {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  border: 2rpx solid #ddd;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  font-size: 20rpx;
  flex-shrink: 0;
}

.mini-check.checked {
  border-color: #4A90A4;
  background: #4A90A4;
  color: #fff;
}

.mini-text {
  font-size: 28rpx;
  color: #555;
}

.mini-goal.done .mini-text {
  text-decoration: line-through;
  color: #ccc;
}

.detail-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
}

.empty-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #bbb;
}
