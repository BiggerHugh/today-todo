/* 语音录入页 */
.page-bg {
  min-height: 100vh;
  background: linear-gradient(180deg, #E8F0F3 0%, #F5F3EF 100%);
}

.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
  margin-bottom: 40rpx;
}

.nav-back {
  font-size: 28rpx;
  color: #4A90A4;
  padding: 12rpx 0;
}

.nav-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #2C2C2C;
}

.nav-spacer {
  width: 80rpx;
}

/* ===== 状态区 ===== */
.state-area {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 600rpx;
  padding: 60rpx 0;
}

/* 初始状态 */
.state-initial {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.pulse-circle {
  position: relative;
  width: 180rpx;
  height: 180rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 60rpx;
}

.pulse-outer {
  position: absolute;
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: rgba(74, 144, 164, 0.1);
  animation: pulse 2s infinite;
}

@keyframes pulse {
  0% { transform: scale(1); opacity: 1; }
  50% { transform: scale(1.15); opacity: 0.5; }
  100% { transform: scale(1); opacity: 1; }
}

.pulse-inner {
  position: relative;
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #4A90A4, #5BA5B8);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  box-shadow: 0 8rpx 24rpx rgba(74, 144, 164, 0.3);
}

.state-text {
  font-size: 28rpx;
  color: #666;
  text-align: center;
  line-height: 1.6;
  margin-bottom: 32rpx;
}

.state-examples {
  display: flex;
  justify-content: center;
}

.example-tag {
  background: rgba(255,255,255,0.7);
  padding: 16rpx 28rpx;
  border-radius: 16rpx;
  font-size: 24rpx;
  color: #999;
  max-width: 500rpx;
  text-align: center;
  line-height: 1.5;
}

/* 录音中 */
.state-recording {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.recording-wave {
  display: flex;
  align-items: flex-end;
  gap: 8rpx;
  height: 160rpx;
  margin-bottom: 40rpx;
}

.wave-bar {
  width: 10rpx;
  background: linear-gradient(180deg, #4A90A4, #5BA5B8);
  border-radius: 5rpx;
  animation: wave 0.6s ease infinite alternate;
}

@keyframes wave {
  from { height: 20rpx; }
  to { height: 140rpx; }
}

.recording-text {
  font-size: 32rpx;
  color: #4A90A4;
  font-weight: 500;
  margin-bottom: 16rpx;
}

.recording-timer {
  font-size: 48rpx;
  font-weight: 200;
  color: #4A90A4;
}

/* AI 处理中 */
.state-processing {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.processing-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 6rpx solid rgba(74, 144, 164, 0.15);
  border-top-color: #4A90A4;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 40rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.raw-text {
  margin-top: 24rpx;
  padding: 20rpx 32rpx;
  background: rgba(255,255,255,0.6);
  border-radius: 16rpx;
  font-size: 26rpx;
  color: #999;
  max-width: 500rpx;
  text-align: center;
}

/* 提炼结果 */
.state-result {
  width: 100%;
}

.result-hint {
  text-align: center;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 32rpx;
}

.goal-card {
  display: flex;
  align-items: center;
  background: rgba(255,255,255,0.9);
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.03);
}

.goal-index {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #4A90A4, #5BA5B8);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 600;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.goal-edit-input {
  flex: 1;
  font-size: 28rpx;
  color: #2C2C2C;
  height: 60rpx;
}

.goal-delete {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ccc;
  font-size: 24rpx;
  flex-shrink: 0;
}

.add-goal-btn {
  text-align: center;
  padding: 24rpx;
  font-size: 26rpx;
  color: #4A90A4;
  opacity: 0.7;
}

/* 错误 */
.state-error {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.error-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.error-text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 32rpx;
}

.retry-btn {
  padding: 16rpx 48rpx;
  background: rgba(74, 144, 164, 0.1);
  color: #4A90A4;
  border-radius: 40rpx;
  font-size: 26rpx;
}

/* ===== 底部操作 ===== */
.action-area {
  padding: 40rpx 0 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.record-btn {
  width: 360rpx;
  height: 360rpx;
  border-radius: 50%;
  background: white;
  border: 4rpx solid #4A90A4;
  color: #4A90A4;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: 600;
  letter-spacing: 4rpx;
  box-shadow: 0 8rpx 32rpx rgba(74, 144, 164, 0.2);
  transition: all 0.15s ease;
}

.record-btn.recording {
  background: linear-gradient(135deg, #FF6B6B, #FF5252);
  border-color: #FF5252;
  color: white;
  transform: scale(1.05);
  box-shadow: 0 12rpx 40rpx rgba(255, 107, 107, 0.4);
  animation: recordPulse 1.5s infinite;
}

@keyframes recordPulse {
  0% { box-shadow: 0 0 0 0 rgba(255, 107, 107, 0.4); }
  70% { box-shadow: 0 0 0 40rpx rgba(255, 107, 107, 0); }
  100% { box-shadow: 0 0 0 0 rgba(255, 107, 107, 0); }
}

.confirm-btn {
  width: 500rpx;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #4A90A4, #5BA5B8);
  color: #fff;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(74, 144, 164, 0.35);
}

.redo-hint {
  margin-top: 24rpx;
  font-size: 26rpx;
  color: #aaa;
  padding: 12rpx 24rpx;
}
