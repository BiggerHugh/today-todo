/* 今日卡片页 */
.page-bg {
  min-height: 100vh;
  transition: background 0.6s ease;
}

/* ===== 顶部日期 ===== */
.header-area {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.date-badge {
  display: flex;
  align-items: flex-end;
  gap: 12rpx;
}

.date-day {
  font-size: 80rpx;
  font-weight: 200;
  color: #2C2C2C;
  line-height: 1;
  letter-spacing: -4rpx;
}

.date-meta {
  display: flex;
  flex-direction: column;
  padding-bottom: 8rpx;
}

.date-month {
  font-size: 28rpx;
  color: #666;
  font-weight: 500;
}

.date-week {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
}

.header-right {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding-top: 8rpx;
}

.header-streak {
  background: linear-gradient(135deg, #FF9A56, #FF6B6B);
  color: #fff;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.header-hint {
  font-size: 24rpx;
  color: #999;
  padding: 8rpx 16rpx;
  background: rgba(255,255,255,0.6);
  border-radius: 20rpx;
}

/* ===== 问候语 ===== */
.greeting {
  font-size: 30rpx;
  color: #555;
  margin-bottom: 40rpx;
  font-weight: 400;
}

/* ===== 目标卡片 ===== */
.goals-section {
  min-height: 300rpx;
}

.goal-card {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.92);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.03);
  border: 1.5rpx solid rgba(0,0,0,0.04);
  transition: all 0.3s ease;
  animation: slideIn 0.45s ease both;
  position: relative;
}

@keyframes slideIn {
  from {
    opacity: 0;
    transform: translateY(24rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.goal-card.done {
  background: rgba(255, 255, 255, 0.6);
  opacity: 0.7;
}

/* 拖拽手柄 */
.goal-handle {
  padding: 8rpx 12rpx 8rpx 0;
  display: flex;
  align-items: center;
}

.handle-dots {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.dot {
  width: 6rpx;
  height: 6rpx;
  border-radius: 50%;
  background: #ccc;
}

/* 内容 */
.goal-content {
  flex: 1;
  padding: 0 16rpx;
}

.goal-text {
  font-size: 30rpx;
  color: #2C2C2C;
  line-height: 1.5;
}

.goal-card.done .goal-text {
  text-decoration: line-through;
  color: #bbb;
}

.goal-time {
  font-size: 22rpx;
  color: #ccc;
  margin-top: 8rpx;
  display: block;
}

/* 完成勾选 */
.goal-check {
  padding: 8rpx;
}

.check-circle {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  border: 3rpx solid #ddd;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

.check-circle.checked {
  border-color: #4A90A4;
  background: linear-gradient(135deg, #4A90A4, #5BA5B8);
  animation: checkPop 0.35s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

@keyframes checkPop {
  0% { transform: scale(1); }
  50% { transform: scale(1.25); }
  100% { transform: scale(1); }
}

.check-icon {
  color: #fff;
  font-size: 24rpx;
  font-weight: bold;
}

/* ===== 进度条 ===== */
.progress-bar {
  margin-top: 32rpx;
  padding: 0 8rpx;
}

.progress-text {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.progress-track {
  height: 6rpx;
  background: rgba(0,0,0,0.06);
  border-radius: 3rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #4A90A4, #5BA5B8);
  border-radius: 3rpx;
  transition: width 0.5s ease;
}

/* ===== 语音按钮 ===== */
.voice-cta {
  margin-top: 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.voice-btn {
  width: 100%;
  height: 120rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  background: linear-gradient(135deg, #4A90A4 0%, #5BA5B8 100%);
  border-radius: 60rpx;
  border: none;
  box-shadow: 0 12rpx 32rpx rgba(74, 144, 164, 0.35);
  transition: all 0.25s ease;
}

.voice-btn:active {
  transform: scale(0.97);
  box-shadow: 0 6rpx 20rpx rgba(74, 144, 164, 0.25);
}

.voice-btn-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.2);
  display: flex;
  align-items: center;
  justify-content: center;
}

.mic-icon {
  font-size: 32rpx;
}

.voice-btn-text {
  color: #fff;
  font-size: 34rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
}

.voice-hint {
  font-size: 24rpx;
  color: #bbb;
  margin-top: 20rpx;
}

/* ===== 手动输入 ===== */
.manual-toggle {
  text-align: center;
  margin-top: 24rpx;
  font-size: 24rpx;
  color: #aaa;
  padding: 16rpx;
}

.quick-add {
  background: rgba(255,255,255,0.9);
  border-radius: 20rpx;
  padding: 8rpx 24rpx;
  margin-top: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.quick-input {
  height: 80rpx;
  font-size: 28rpx;
  width: 100%;
}

.input-placeholder {
  color: #ccc;
}

.quick-actions {
  display: flex;
  justify-content: flex-end;
  gap: 24rpx;
  padding: 12rpx 0;
  border-top: 1rpx solid rgba(0,0,0,0.04);
}

.quick-cancel {
  color: #999;
  font-size: 26rpx;
  padding: 8rpx 16rpx;
}

.quick-confirm {
  color: #4A90A4;
  font-size: 26rpx;
  font-weight: 600;
  padding: 8rpx 16rpx;
}

/* ===== 空状态 ===== */
.empty-illustration {
  margin-bottom: 24rpx;
}

.empty-icon {
  font-size: 120rpx;
}
