<!-- 我的页面 -->
<view class="page-bg">
  <view class="container fade-in">

    <!-- 统计卡片 -->
    <view class="stats-card">
      <view class="stat-item">
        <text class="stat-num">{{stats.streak}}</text>
        <text class="stat-label">连续天数</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-num">{{stats.totalDays}}</text>
        <text class="stat-label">记录天数</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-num">{{stats.completionRate}}%</text>
        <text class="stat-label">完成率</text>
      </view>
    </view>

    <!-- 提醒设置 -->
    <view class="section-title">提醒设置</view>
    <view class="settings-card">
      <view class="setting-row">
        <view class="setting-info">
          <text class="setting-label">🌅 早上立目标提醒</text>
          <text class="setting-desc">每天早上提醒你立下今日目标</text>
        </view>
        <switch 
          checked="{{settings.morningReminder}}" 
          bindchange="toggleMorning"
          color="#4A90A4"
        />
      </view>
      <view class="setting-row time-row" wx:if="{{settings.morningReminder}}">
        <text class="time-label">提醒时间</text>
        <picker 
          mode="time" 
          value="{{settings.morningTime}}"
          bindchange="onMorningTimeChange"
        >
          <view class="time-value">{{settings.morningTime}}</view>
        </picker>
      </view>

      <view class="divider"></view>

      <view class="setting-row">
        <view class="setting-info">
          <text class="setting-label">🌙 晚上回顾提醒</text>
          <text class="setting-desc">每天晚上提醒你回顾今日完成情况</text>
        </view>
        <switch 
          checked="{{settings.eveningReminder}}" 
          bindchange="toggleEvening"
          color="#4A90A4"
        />
      </view>
      <view class="setting-row time-row" wx:if="{{settings.eveningReminder}}">
        <text class="time-label">提醒时间</text>
        <picker 
          mode="time" 
          value="{{settings.eveningTime}}"
          bindchange="onEveningTimeChange"
        >
          <view class="time-value">{{settings.eveningTime}}</view>
        </picker>
      </view>
    </view>

    <!-- 关于 -->
    <view class="section-title">关于</view>
    <view class="about-card">
      <view class="about-row">
        <text class="about-label">版本</text>
        <text class="about-value">1.0.0</text>
      </view>
      <view class="about-row">
        <text class="about-label">理念</text>
        <text class="about-value">今日事今日毕</text>
      </view>
    </view>

    <view class="footer-text">
      每天对自己说一次「我要做什么」<br/>
      每天对自己问一次「我做了什么」
    </view>
  </view>
</view>
